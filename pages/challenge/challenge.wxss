/* pages/challenge/challenge.wxss */
@import '../../app.wxss';

.container {
  min-height: 100vh;
  background: var(--light-blue);
  padding: 0 30rpx 60rpx;
}

/* 头部样式 */
.challenge-header {
  padding: 40rpx 0 30rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.header-back {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 30rpx;
}

.header-back .icon {
  margin-right: 10rpx;
  font-weight: bold;
}

.challenge-title-section {
  margin-bottom: 20rpx;
}

.challenge-title {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--dark-blue);
  line-height: 1.4;
  display: block;
  margin-bottom: 15rpx;
}

.challenge-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.meta-item {
  font-size: 24rpx;
  color: var(--text-secondary);
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  background: var(--light-gray);
}

.difficulty-easy {
  background: var(--success-light);
  color: var(--success);
}

.difficulty-medium {
  background: var(--warning-light);
  color: var(--warning);
}

.difficulty-hard {
  background: var(--danger-light);
  color: var(--danger);
}

/* 书籍信息 */
.book-info {
  display: flex;
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin: 30rpx 0;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}

.book-cover {
  width: 160rpx;
  height: 200rpx;
  border-radius: 8rpx;
  margin-right: 30rpx;
  background: var(--light-gray);
}

.book-details {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.book-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--dark-blue);
  margin-bottom: 10rpx;
  line-height: 1.4;
}

.book-author {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 10rpx;
}

.book-grade {
  font-size: 24rpx;
  color: var(--primary-blue);
  padding: 4rpx 12rpx;
  background: var(--light-blue);
  border-radius: 6rpx;
  align-self: flex-start;
}

/* 挑战描述 */
.challenge-description {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--dark-blue);
  display: block;
  margin-bottom: 20rpx;
}

.description-text {
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.6;
}

/* 计时器 */
.timer-section {
  display: flex;
  justify-content: center;
  align-items: center;
  background: white;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
}

.timer-label {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-right: 15rpx;
}

.timer-value {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--primary-blue);
}

/* 进度条 */
.progress-section {
  margin-bottom: 40rpx;
}

.progress-bar {
  height: 12rpx;
  background: var(--light-gray);
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 15rpx;
}

.progress-fill {
  height: 100%;
  background: var(--primary-blue);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  text-align: center;
  display: block;
}

/* 问题区域 */
.question-section {
  background: white;
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}

.question-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 25rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.question-number {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--primary-blue);
}

.question-points {
  font-size: 26rpx;
  color: var(--warning);
  background: var(--warning-light);
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.question-text {
  font-size: 32rpx;
  color: var(--text-primary);
  line-height: 1.5;
  margin-bottom: 40rpx;
  display: block;
}

/* 选择题选项 */
.options-container {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.option-item {
  display: flex;
  align-items: center;
  padding: 25rpx 30rpx;
  background: var(--light-gray);
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.option-item.selected {
  background: var(--light-blue);
  border-color: var(--primary-blue);
}

.option-letter {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--primary-blue);
  width: 50rpx;
  margin-right: 20rpx;
}

.option-text {
  font-size: 28rpx;
  color: var(--text-primary);
  flex: 1;
}

/* 判断题选项 */
.true-false-container {
  display: flex;
  gap: 30rpx;
}

.tf-option {
  flex: 1;
  padding: 30rpx;
  background: var(--light-gray);
  border-radius: 12rpx;
  text-align: center;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.tf-option.selected {
  background: var(--light-blue);
  border-color: var(--primary-blue);
}

.tf-option text {
  font-size: 28rpx;
  color: var(--text-primary);
}

/* 简答题 */
.short-answer-container {
  margin-top: 20rpx;
}

.short-answer-input {
  width: 100%;
  min-height: 200rpx;
  padding: 25rpx;
  background: var(--light-gray);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.5;
  border: 2rpx solid transparent;
}

.short-answer-input:focus {
  border-color: var(--primary-blue);
}

.word-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 10rpx;
}

/* 即时反馈 */
.feedback-message {
  margin-top: 30rpx;
  padding: 20rpx 30rpx;
  border-radius: 12rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 500;
  opacity: 0;
  transform: translateY(10rpx);
  transition: all 0.3s ease;
}

.feedback-message.show {
  opacity: 1;
  transform: translateY(0);
}

.feedback-message.correct {
  background: var(--success-light);
  color: var(--success);
}

.feedback-message.incorrect {
  background: var(--danger-light);
  color: var(--danger);
}

/* 导航按钮 */
.navigation-buttons {
  display: flex;
  gap: 30rpx;
  margin-bottom: 40rpx;
}

.nav-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 30rpx;
  border-radius: 12rpx;
  border: none;
}

.prev-btn {
  background: var(--light-gray);
  color: var(--text-secondary);
}

.prev-btn:not(.disabled):active {
  background: var(--gray);
}

.next-btn {
  background: var(--primary-blue);
  color: white;
}

.next-btn:not(.disabled):active {
  background: var(--dark-blue);
}

.nav-btn.disabled {
  opacity: 0.5;
}

/* 提交按钮 */
.submit-section {
  margin-bottom: 40rpx;
}

.submit-btn {
  width: 100%;
  height: 90rpx;
  line-height: 90rpx;
  font-size: 32rpx;
  font-weight: bold;
  background: var(--success);
  color: white;
  border-radius: 16rpx;
  border: none;
}

.submit-btn.disabled {
  background: var(--success-light);
  opacity: 0.7;
}

/* 结果区域 */
.result-section {
  background: white;
  border-radius: 16rpx;
  padding: 40rpx;
  margin-top: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}

.result-header {
  text-align: center;
  margin-bottom: 40rpx;
  padding-bottom: 30rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.result-title {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--success);
  display: block;
  margin-bottom: 15rpx;
}

.result-score {
  font-size: 48rpx;
  font-weight: bold;
  color: var(--primary-blue);
}

.result-details {
  display: flex;
  flex-direction: column;
  gap: 25rpx;
  margin-bottom: 40rpx;
}

.result-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.result-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.result-value {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--text-primary);
}

.result-actions {
  display: flex;
  gap: 30rpx;
}

.action-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 30rpx;
  border-radius: 12rpx;
  border: none;
}

.retry-btn {
  background: var(--warning);
  color: white;
}

.list-btn {
  background: var(--light-gray);
  color: var(--text-primary);
}

/* 解析弹窗 */
.explanation-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
  z-index: 1000;
}

.explanation-modal.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  width: 90%;
  max-width: 600rpx;
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 35rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--dark-blue);
}

.modal-close {
  font-size: 40rpx;
  color: var(--text-secondary);
  line-height: 1;
}

.modal-body {
  padding: 35rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.modal-body text {
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.6;
}

/* 加载状态 */
.loading-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: var(--light-blue);
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid var(--light-gray);
  border-top-color: var(--primary-blue);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 30rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-container text {
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* 错误状态 */
.error-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: var(--light-blue);
  padding: 60rpx;
}

.error-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.error-text {
  font-size: 32rpx;
  color: var(--danger);
  text-align: center;
  margin-bottom: 40rpx;
  line-height: 1.5;
}

.error-btn {
  width: 200rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 30rpx;
  background: var(--primary-blue);
  color: white;
  border-radius: 12rpx;
  border: none;
}