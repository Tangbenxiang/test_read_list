/* pages/sharing-detail/sharing-detail.wxss */
@import '../../app.wxss';

.container {
  min-height: 100vh;
  background: var(--light-blue);
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder {
  text-align: center;
  padding: 60rpx;
}

.placeholder-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  color: var(--primary-blue);
}

.placeholder-title {
  display: block;
  font-size: 42rpx;
  font-weight: bold;
  color: var(--dark-blue);
  margin-bottom: 20rpx;
}

.placeholder-subtitle {
  font-size: 28rpx;
  color: var(--text-secondary);
}