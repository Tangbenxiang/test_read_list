/* pages/profile/profile.wxss */
@import '../../app.wxss';

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, var(--primary-blue) 0%, var(--light-blue) 100%);
  padding-bottom: 40rpx;
}

/* 顶部背景区域 */
.header-bg {
  height: 320rpx;
  background: linear-gradient(135deg, #7BC6FF 0%, #4DA6FF 50%, #3388FF 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  border-radius: 0 0 60rpx 60rpx;
  box-shadow: 0 4rpx 30rpx rgba(77, 166, 255, 0.3);
  margin-bottom: 30rpx;
}

.edit-btn {
  position: absolute;
  top: 40rpx;
  right: 40rpx;
  font-size: 40rpx;
  color: white;
  opacity: 0.8;
  transition: all 0.3s ease;
  padding: 10rpx;
}

.edit-btn:active {
  opacity: 1;
  transform: scale(1.1);
}

.user-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: white;
  border: 6rpx solid white;
  box-shadow: 0 8rpx 25rpx rgba(0, 0, 0, 0.2);
  margin-bottom: 20rpx;
  overflow: hidden;
}

.avatar-image {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 80rpx;
  background: #F8FBFF;
  border-radius: 50%;
}

.user-name {
  font-size: 42rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 10rpx;
  text-align: center;
}

.user-role {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  padding: 6rpx 20rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
}

/* 加载容器 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 8rpx solid rgba(160, 214, 255, 0.3);
  border-top: 8rpx solid var(--primary-blue);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 30rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* 个人资料内容 */
.profile-content {
  padding: 0 30rpx;
}

/* 信息卡片 */
.info-card {
  background: white;
  border-radius: var(--radius-medium);
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: var(--shadow-light);
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.card-icon {
  font-size: 36rpx;
  margin-right: 15rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--dark-blue);
  flex: 1;
}

.points-badge {
  display: flex;
  align-items: center;
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  border-radius: 20rpx;
  box-shadow: 0 4rpx 10rpx rgba(255, 165, 0, 0.2);
}

.points-icon {
  font-size: 24rpx;
  margin-right: 6rpx;
  color: white;
}

.points-value {
  font-size: 28rpx;
  font-weight: bold;
  color: white;
}

.refresh-btn {
  display: flex;
  align-items: center;
  padding: 8rpx 20rpx;
  background: rgba(160, 214, 255, 0.1);
  border-radius: 20rpx;
  border: 2rpx solid var(--primary-blue);
}

.refresh-text {
  font-size: 24rpx;
  color: var(--dark-blue);
  margin-right: 8rpx;
}

.refresh-icon {
  font-size: 24rpx;
  color: var(--dark-blue);
}

.view-all-btn {
  display: flex;
  align-items: center;
  padding: 8rpx 20rpx;
  background: rgba(160, 214, 255, 0.1);
  border-radius: 20rpx;
  border: 2rpx dashed var(--primary-blue);
}

.view-all-text {
  font-size: 24rpx;
  color: var(--dark-blue);
  margin-right: 8rpx;
}

.view-all-icon {
  font-size: 18rpx;
  color: var(--dark-blue);
}

/* 信息网格 */
.info-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.info-item {
  display: flex;
  flex-direction: column;
}

.info-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.info-value {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--dark-blue);
  padding: 10rpx 0;
}

/* 统计网格 */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.stat-item {
  text-align: center;
}

.stat-number {
  display: block;
  font-size: 42rpx;
  font-weight: bold;
  color: var(--dark-blue);
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 进度条 */
.stats-progress {
  margin-top: 20rpx;
}

.progress-bar {
  height: 20rpx;
  background: #F0F7FF;
  border-radius: 10rpx;
  overflow: hidden;
  margin-bottom: 10rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--primary-blue) 0%, var(--secondary-blue) 100%);
  border-radius: 10rpx;
  transition: width 0.5s ease;
}

.progress-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  text-align: center;
}

/* 成就网格 */
.achievements-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.achievement-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  border-radius: var(--radius-small);
  background: #F8FBFF;
  border: 2rpx solid var(--ice-blue);
  transition: all 0.3s ease;
}

.achievement-item.unlocked {
  background: var(--ice-blue);
  border-color: var(--primary-blue);
  transform: translateY(-4rpx);
  box-shadow: 0 6rpx 15rpx rgba(160, 214, 255, 0.3);
}

.achievement-item.locked {
  opacity: 0.7;
}

.achievement-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.achievement-name {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--dark-blue);
  text-align: center;
  margin-bottom: 6rpx;
}

.achievement-status {
  font-size: 20rpx;
  color: var(--text-light);
  text-align: center;
}

.achievement-item.unlocked .achievement-status {
  color: #52C41A;
  font-weight: bold;
}

/* 活动列表 */
.activities-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.activity-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #F8FBFF;
  border-radius: var(--radius-small);
  border: 2rpx solid var(--ice-blue);
}

.activity-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
  color: var(--dark-blue);
}

.activity-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.activity-title {
  font-size: 28rpx;
  color: var(--text-primary);
  margin-bottom: 6rpx;
}

.activity-time {
  font-size: 24rpx;
  color: var(--text-light);
}

/* 快捷操作 */
.quick-actions {
  margin-bottom: 40rpx;
}

.section-title {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: var(--dark-blue);
}

.section-icon {
  font-size: 36rpx;
  margin-right: 15rpx;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 20rpx;
  background: white;
  border-radius: var(--radius-medium);
  box-shadow: var(--shadow-light);
  transition: all 0.3s ease;
}

.action-item:active {
  transform: translateY(-4rpx);
  box-shadow: var(--shadow-medium);
}

.action-icon {
  font-size: 60rpx;
  margin-bottom: 15rpx;
  height: 60rpx;
  line-height: 60rpx;
}

.action-text {
  font-size: 24rpx;
  color: var(--text-primary);
  text-align: center;
}

/* 隐私说明 */
.privacy-notice {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  background: #F8FBFF;
  border-radius: var(--radius-small);
  margin-top: 20rpx;
}

.notice-icon {
  font-size: 24rpx;
  margin-right: 10rpx;
  color: var(--text-light);
}

.notice-text {
  font-size: 24rpx;
  color: var(--text-light);
  flex: 1;
  text-align: center;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .info-grid {
    grid-template-columns: 1fr;
  }

  .achievements-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .action-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .user-avatar {
    width: 120rpx;
    height: 120rpx;
  }

  .achievement-icon {
    font-size: 40rpx;
  }
}