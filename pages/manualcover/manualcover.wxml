<view class="container">
  <!-- 权限检查提示 -->
  <view wx:if="{{checkingAdmin}}" class="permission-checking">
    <text>检查权限中...</text>
  </view>
  <view wx:elif="{{!isAdmin}}" class="permission-error">
    <text>{{errorMessage || '您没有权限访问此页面'}}</text>
    <button class="btn back-btn" bindtap="goBack">返回</button>
  </view>

  <view wx:else>
    <!-- 当前书籍信息 -->
    <view class="book-info-section" wx:if="{{book}}">
      <text class="section-title">当前书籍</text>
      <view class="book-card">
        <view class="book-header">
          <image class="current-cover" src="{{book.cover || '/images/default-cover.png'}}" mode="aspectFit"></image>
          <view class="book-details">
            <text class="book-title">{{book.title}}</text>
            <text class="book-author">{{book.author}}</text>
            <view class="book-tags">
              <text class="book-tag">{{book.type || '未分类'}}</text>
              <text class="book-tag">{{book.gradeLevel || '未分类'}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 封面修改选项 -->
    <view class="options-section">
      <text class="section-title">修改封面</text>

      <!-- 选项1: 上传图片 -->
      <view class="option-card">
        <text class="option-title">📷 上传图片</text>
        <text class="option-desc">从手机相册选择封面图片</text>
        <button class="option-btn" bindtap="chooseImage">选择图片</button>

        <!-- 图片预览 -->
        <image
          wx:if="{{tempImagePath}}"
          src="{{tempImagePath}}"
          class="image-preview"
          mode="aspectFit"
        />

        <!-- 上传进度 -->
        <view wx:if="{{uploading}}" class="upload-progress">
          <progress percent="{{uploadProgress}}" show-info />
          <text class="progress-text">{{uploadProgress}}%</text>
        </view>
      </view>

      <!-- 选项2: 拍照 -->
      <view class="option-card">
        <text class="option-title">📸 拍照</text>
        <text class="option-desc">使用相机拍摄封面照片</text>
        <button class="option-btn" bindtap="takePhoto">拍照</button>
      </view>

      <!-- 选项3: 填写链接 -->
      <view class="option-card">
        <text class="option-title">🔗 填写图片链接</text>
        <text class="option-desc">输入封面图片的网络地址</text>
        <view class="url-input-group">
          <input
            class="url-input"
            placeholder="请输入封面图片链接 (http://...)"
            value="{{coverUrl}}"
            bindinput="onUrlInput"
          />
          <button class="url-confirm-btn" bindtap="updateWithUrl" size="mini">确定</button>
        </view>
        <text class="url-hint">支持常见的图片格式链接</text>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-buttons">
      <button class="btn back-btn" bindtap="goBack">返回详情</button>
    </view>
  </view>
</view>