<!-- pages/index/index.wxml -->
<view class="container page-content">
  <!-- 顶部背景区域 -->
  <view class="header-bg">
    <view class="user-avatar" bindtap="goToProfile">
      <image wx:if="{{userInfo && userInfo.avatar}}" class="avatar-image" src="{{userInfo.avatar}}" mode="aspectFill" />
      <view wx:else class="avatar-placeholder">👤</view>
      <text wx:if="{{userInfo && userInfo.anonymousName}}" class="avatar-name">{{userInfo.anonymousName}}</text>
    </view>
    <view class="admin-icon" bindtap="goToAddBook">➕</view>
    <text class="title">阅读记录小助手</text>
    <text class="subtitle">和Shelly一起探索书海，爱上阅读</text>
  </view>

  <!-- 搜索栏 -->
  <view class="search-bar" bindtap="goToSearch">
    <view class="search-icon">🔍</view>
    <text class="search-placeholder">搜索书名、作者或类型</text>
  </view>

  <!-- 学生专区 -->
  <view class="section-title">
    <view class="section-icon">👦</view>
    <text>学生专区</text>
  </view>

  <view class="grade-cards">
    <view class="grade-card grade-1" bindtap="goToList" data-grade="一至二年级">
      <text class="grade-name">一至二年级</text>
      <text class="book-count">{{stats.grade1}}本</text>
      <view class="card-icon">👧</view>
    </view>

    <view class="grade-card grade-2" bindtap="goToList" data-grade="三至四年级">
      <text class="grade-name">三至四年级</text>
      <text class="book-count">{{stats.grade2}}本</text>
      <view class="card-icon">👩</view>
    </view>

    <view class="grade-card grade-3" bindtap="goToList" data-grade="五至六年级">
      <text class="grade-name">五至六年级</text>
      <text class="book-count">{{stats.grade3}}本</text>
      <view class="card-icon">👸</view>
    </view>
  </view>

  <!-- 挑战专区（已隐藏） -->
  <!--
  <view class="section-title">
    <view class="section-icon">🏆</view>
    <text>挑战专区</text>
  </view>

  <view class="parent-section">
    <view class="parent-card" bindtap="goToChallenge">
      <view class="parent-icon">🏆</view>
      <text class="parent-text">挑战专区</text>
      <text class="parent-desc">参与阅读挑战，赢取奖励</text>
    </view>
  </view>
  -->

  <!-- 快捷入口 -->
  <view class="section-title">
    <view class="section-icon">⚡</view>
    <text>快捷入口</text>
  </view>

  <view class="quick-entries">
    <view class="quick-entry" bindtap="goToUnread">
      <view class="entry-icon">📖</view>
      <text class="entry-text">未阅读</text>
      <text class="entry-count">{{stats.unread}}本</text>
    </view>

    <view class="quick-entry" bindtap="goToPurchased">
      <view class="entry-icon">🛒</view>
      <text class="entry-text">未购买</text>
      <text class="entry-count">{{(stats.grade1 + stats.grade2 + stats.grade3) - stats.purchased}}本</text>
    </view>

    <view class="quick-entry" bindtap="goToIntensive">
      <view class="entry-icon">⭐</view>
      <text class="entry-text">已精读</text>
      <text class="entry-count">{{stats.intensive}}本</text>
    </view>

    <view class="quick-entry" bindtap="goToAllBooks">
      <view class="entry-icon">📚</view>
      <text class="entry-text">全部书籍</text>
      <text class="entry-count">{{stats.grade1 + stats.grade2 + stats.grade3}}本</text>
    </view>

    <view class="quick-entry" bindtap="goToFeedback">
      <view class="entry-icon">💬</view>
      <text class="entry-text">意见建议</text>
    </view>
    <!-- 个人中心入口（已隐藏）
    <view class="quick-entry" bindtap="goToProfile">
      <view class="entry-icon">👤</view>
      <text class="entry-text">个人中心</text>
    </view>
    -->
  </view>

  <!-- 计划阅读书籍 -->
  <view class="section-title">
    <view class="section-icon">📚</view>
    <text>计划阅读书籍</text>
    <view class="add-book-btn" bindtap="goToAddPlannedBook">➕</view>
  </view>

  <view class="planned-books-section">
    <view wx:if="{{plannedBooks && plannedBooks.length > 0}}" class="planned-books-list">
      <view wx:for="{{plannedBooks}}" wx:key="bookId" class="planned-book-item" bindtap="viewPlannedBook" data-book-id="{{item.bookId}}">
        <image wx:if="{{item.bookInfo.cover}}" class="book-cover" src="{{item.bookInfo.cover}}" mode="aspectFill" />
        <view wx:else class="book-cover-placeholder">📖</view>
        <view class="book-info">
          <text class="book-title">{{item.bookInfo.title}}</text>
          <text class="book-author">{{item.bookInfo.author}}</text>
          <text class="book-status {{item.status}}">{{item.status === 'planned' ? '计划阅读' : item.status === 'reading' ? '正在阅读' : '已完成'}}</text>
        </view>
      </view>
    </view>
    <view wx:else class="empty-planned-books">
      <text>暂无计划阅读书籍，点击➕添加</text>
    </view>
  </view>

  <!-- 数据统计 -->
  <view class="section-title">
    <view class="section-icon">📊</view>
    <text>数据统计</text>
  </view>

  <view class="stats-cards">
    <view class="stat-card">
      <text class="stat-number">{{stats.grade1 + stats.grade2 + stats.grade3}}</text>
      <text class="stat-label">总书籍</text>
    </view>
    <view class="stat-card">
      <text class="stat-number">{{stats.purchased}}</text>
      <text class="stat-label">已购买</text>
    </view>
    <view class="stat-card">
      <text class="stat-number">{{(stats.grade1 + stats.grade2 + stats.grade3) - stats.unread}}</text>
      <text class="stat-label">已阅读</text>
    </view>
    <view class="stat-card">
      <text class="stat-number">{{stats.intensive}}</text>
      <text class="stat-label">已精读</text>
    </view>
  </view>

  <!-- 加载提示 -->
  <view wx:if="{{loading}}" class="loading">加载中...</view>
</view>